opencode/env

# Machine-local install answers (work-computer flag, etc.) — never shared.
.dotfiles-local

# Pi coding agent — project-local artifacts.
# Global settings now live at ~/.pi/agent/settings.json (linked by
# install.sh). Any .pi/ that pi creates inside this repo is local-only.
.pi/

# Scorecard (work) — never track work-specific files in this shared repo.
*scorecard*

# mise runtimes are machine-local: install.sh seeds this from
# mise/config.toml.example, then the machine owns it. Per-machine tool choices
# (e.g. bun on one box) stay out of the shared repo.
mise/config.toml

# Machine-only global-rules section, appended to the generated ~/CLAUDE.md /
# ~/AGENTS.md by install.sh. Shared sections live in tracked rules.d/ files.
agent-skills/rules.d/99-local.md

# Machine-local Claude Code settings, merged over the repo's settings.json into
# ~/.claude/settings.json by install.sh (local wins). Shared keys stay in
# claude-code/settings.json.
claude-code/settings.local.json
