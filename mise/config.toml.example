# Seed for ~/.config/mise/config.toml. install.sh (PHASE 1b) copies this to a
# real, machine-local config when a machine has none. The live config is
# untracked, so per-machine tools never land in this shared repo.
#
# node/go exist so nvim's Mason can build the language servers it auto-installs:
# gopls needs Go, ts_ls/pyright need Node. Python is machine-local via a conf.d
# overlay (see the mise skill), not here.
[tools]
node = "lts"
go = "latest"
